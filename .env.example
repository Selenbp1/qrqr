# 서버 포트
PORT=3000
HOST=0.0.0.0

# QR에 들어갈 고정 URL — configure-local.cmd 로 PC IP 기준 자동 설정 가능
# 명함용(외부 접속): 공유기 포트포워딩 후 PUBLIC_HOST=공인IP 로 설정하고 configure-local.cmd 실행
# PUBLIC_HOST=123.456.789.0
PUBLIC_URL=http://127.0.0.1:3000

# 리다이렉트 목적지 — 변경 시 서버 재시작 (QR 재생성 불필요)
